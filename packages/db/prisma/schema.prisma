generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum RepoProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum Framework {
  NEXTJS
  REACT
  VUE
  NUXT
  REMIX
  ASTRO
  ANGULAR
  SVELTE
  EXPRESS
  FASTAPI
  DJANGO
  RAILS
  LARAVEL
  DOCKER
  STATIC
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  DELETED
}

enum DeploymentEnvironment {
  PRODUCTION
  PREVIEW
  DEVELOPMENT
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  READY
  ERROR
  CANCELLED
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

enum SslStatus {
  PENDING
  ACTIVE
  FAILED
  EXPIRED
}

enum EnvEnvironment {
  PRODUCTION
  PREVIEW
  DEVELOPMENT
  ALL
}

enum DatabaseType {
  POSTGRES
  REDIS
  MYSQL
  MONGODB
}

enum DatabaseStatus {
  PROVISIONING
  ACTIVE
  STOPPED
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  password         String
  name             String?
  avatar           String?
  githubId         String?          @unique
  gitlabId         String?          @unique
  bitbucketId      String?          @unique
  twoFactorSecret  String?
  twoFactorEnabled Boolean          @default(false)
  role             Role             @default(USER)
  
  teams            TeamMember[]
  projects         Project[]
  deployments      Deployment[]
  apiTokens        ApiToken[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Team {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  avatar      String?
  plan        Plan         @default(FREE)
  ownerId     String
  
  members     TeamMember[]
  projects    Project[]
  deployments Deployment[]
  domains     Domain[]
  envVars     EnvironmentVariable[]
  apiTokens   ApiToken[]
  webhooks    Webhook[]
  auditLogs   AuditLog[]
  databases   ManagedDatabase[]
  notifications Notification[]
  usageRecords UsageRecord[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id             String   @id @default(cuid())
  teamId         String
  userId         String
  role           TeamRole @default(MEMBER)
  inviteToken    String?  @unique
  inviteAccepted Boolean  @default(false)
  
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime @default(now())

  @@unique([teamId, userId])
}

model Project {
  id              String           @id @default(cuid())
  name            String
  slug            String
  teamId          String
  userId          String
  
  repoProvider    RepoProvider
  repoUrl         String
  repoId          String
  repoBranch      String           @default("main")
  rootDirectory   String?          @default("/")
  
  framework       Framework
  buildCommand    String?
  installCommand  String?
  startCommand    String?
  outputDirectory String?
  nodeVersion     String           @default("20.x")
  pythonVersion   String?
  
  status          ProjectStatus    @default(ACTIVE)
  
  team            Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id])
  
  deployments     Deployment[]
  domains         Domain[]
  envVars         EnvironmentVariable[]
  webhooks        Webhook[]
  databases       ManagedDatabase[]
  
  productionDeploymentId String? @unique
  productionDeployment   Deployment? @relation("ProjectProduction", fields: [productionDeploymentId], references: [id])
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([teamId, slug])
}

model Deployment {
  id              String                @id @default(cuid())
  projectId       String
  teamId          String
  userId          String
  
  commitSha       String?
  commitMessage   String?
  commitAuthor    String?
  branch          String
  environment     DeploymentEnvironment @default(PRODUCTION)
  status          DeploymentStatus      @default(QUEUED)
  url             String?
  buildDuration   Int?                  // in seconds
  deployDuration  Int?                  // in seconds
  meta            Json?
  errorMessage    String?
  
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  producedProject Project?              @relation("ProjectProduction")
  team            Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id])
  
  logs            BuildLog[]
  
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  readyAt         DateTime?
}

model BuildLog {
  id           String     @id @default(cuid())
  deploymentId String
  level        LogLevel   @default(INFO)
  message      String
  timestamp    DateTime   @default(now())
  
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

model Domain {
  id                String    @id @default(cuid())
  projectId         String
  teamId            String
  hostname          String    @unique
  verified          Boolean   @default(false)
  verificationToken String
  sslStatus         SslStatus @default(PENDING)
  sslExpiresAt      DateTime?
  isPrimary         Boolean   @default(false)
  redirectTo        String?
  
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team              Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model EnvironmentVariable {
  id          String         @id @default(cuid())
  projectId   String
  teamId      String
  key         String
  value       String         // encrypted
  environment EnvEnvironment @default(ALL)
  isSecret    Boolean        @default(true)
  
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team        Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([projectId, key, environment])
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  teamId     String
  name       String
  token      String    @unique // hashed
  lastUsedAt DateTime?
  scopes     Json?
  expiresAt  DateTime?
  
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime  @default(now())
}

model Webhook {
  id         String            @id @default(cuid())
  projectId  String
  teamId     String
  url        String
  secret     String
  events     Json
  active     Boolean           @default(true)
  
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team       Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  deliveries WebhookDelivery[]
  
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  webhookId      String
  event          String
  payload        Json
  responseStatus Int?
  responseBody   String?
  duration       Int?     // in ms
  success        Boolean
  
  webhook        Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  teamId     String
  userId     String
  action     String
  resource   String
  resourceId String?
  meta       Json?
  ip         String?
  userAgent  String?
  
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())
}

model ManagedDatabase {
  id               String         @id @default(cuid())
  teamId           String
  projectId        String?
  name             String
  type             DatabaseType
  status           DatabaseStatus @default(PROVISIONING)
  host             String
  port             Int
  dbName           String
  username         String
  password         String         // encrypted
  connectionString String         // encrypted
  version          String?
  storageGB        Int            @default(1)
  
  team             Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project          Project?       @relation(fields: [projectId], references: [id])
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  teamId    String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  meta      Json?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?    @relation(fields: [teamId], references: [id])
  
  createdAt DateTime @default(now())
}

model UsageRecord {
  id                  String   @id @default(cuid())
  teamId              String
  month               Int
  year                Int
  bandwidthGB         Float    @default(0)
  buildMinutes        Float    @default(0)
  functionInvocations Int      @default(0)
  deployments         Int      @default(0)
  
  team                Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime @default(now())

  @@unique([teamId, month, year])
}
