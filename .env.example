# Server Configuration
PORT=4000
NODE_ENV=development
APP_DOMAIN=deployflow.app
APP_SUBDOMAIN_BASE=deployflow.dev
FRONTEND_URL=http://localhost:3000

# Database & Redis
DATABASE_URL=postgresql://admin:password@localhost:5432/deployflow?schema=public
REDIS_URL=redis://localhost:6379

# Authentication
JWT_ACCESS_SECRET=your_jwt_access_secret_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_me
JWT_EXPIRES_IN=15m

# Encryption (32 characters)
ENCRYPTION_MASTER_KEY=12345678901234567890123456789012

# Git OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# AWS S3 (or LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_BUCKET=deployflow-artifacts
AWS_REGION=us-east-1

# SMTP Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# Infrastructure
DOCKER_SOCKET_PATH=/var/run/docker.sock
ACME_EMAIL=admin@deployflow.app
ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory

# Admin Configuration
ADMIN_EMAIL=admin@deployflow.app
