{
  "name": "deployflow-monorepo",
  "version": "1.0.1",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --force",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:generate": "npx prisma generate --schema ./packages/db/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema ./packages/db/prisma/schema.prisma --accept-data-loss"
  },
  "devDependencies": {
    "@prisma/client": "^5.12.1",
    "prettier": "^3.0.0",
    "prisma": "^5.12.1",
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4"
  }
}
