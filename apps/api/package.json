{
  "name": "api",
  "version": "1.0.0",
  "description": "DeployFlow Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "set NODE_OPTIONS=--max-old-space-size=400 && npm run prisma:generate && node ../../node_modules/typescript/bin/tsc",
    "start": "node dist/server.js",
    "test": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "prisma:generate": "prisma generate --schema=../../packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../../packages/db/prisma/schema.prisma",
    "prisma:seed": "ts-node src/prisma/seed.ts",
    "test:deploy": "ts-node src/scripts/test-deploy.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/http-proxy": "^1.17.17",
